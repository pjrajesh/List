{
  "expo": {
    "name": "Listorix",
    "slug": "listorix",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "listorix",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.listorix.app",
      "associatedDomains": ["applinks:listorix.com"],
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Add items to your list using your voice",
        "NSCameraUsageDescription": "Scan receipts to auto-log your expenses",
        "NSPhotoLibraryUsageDescription": "Pick a receipt or screenshot to extract items"
      },
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.listorix.app.shared"
        ]
      }
    },
    "android": {
      "package": "com.listorix.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1E3A8A"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "NOTIFICATIONS",
        "RECORD_AUDIO",
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "listorix.com", "pathPrefix": "/join" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#1E3A8A"
        }
      ],
      "expo-web-browser",
      "expo-mail-composer",
      [
        "expo-notifications",
        {
          "color": "#1E3A8A"
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "List",
              "label": "Listorix \u2014 Your List",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "description": "See your active list and quick-add at a glance.",
              "previewImage": "./assets/images/widget-preview.png",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ],
      "@bacons/apple-targets"
    ],
    "extra": {
      "eas": {
        "projectId": "e9de1c84-9ec5-414d-b392-77336c374cf8"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
