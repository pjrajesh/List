        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "sb_publishable_lZ0cJid7KN-z7yzhikxKPQ_LRfSwTlA",
        "EXPO_PUBLIC_INVITE_BASE_URL": "https://listorix.com/join",
